root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true
indent_size = 2
max_line_length = 100

[*.svelte]
quote_type = single

[*.ts]
indent_size = 4

[*.mjs]
indent_size = 4

[*.js]
indent_size = 4

[*.json]
indent_size = 2

[*.md]
indent_size = 2

[*.lark]
indent_size = 4
